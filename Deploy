const cr=await apiCall(token,`/guilds/${guildId}/channels`,'POST',{name:cat.n,type:0,topic:cat.t});
if(!cr.ok){log(`✗ Failed: ${cat.n}`,'err');await sleep(1000);continue;}
const ch=await cr.json();
log(`✓ Created: #${cat.n}`,'ok');
await sleep(800);
await apiCall(token,`/channels/${ch.id}/messages`,'POST',{content:`**${cat.t}**\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n*For authorized research and educational use only*\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`});
await sleep(600);
let batch=[];
for(let t=0;t<cat.tools.length;t++){
const tool=cat.tools[t];
batch.push(`**${tool.n}**\n${tool.d}\n🔗 ${tool.u}`);
if(batch.length===5||t===cat.tools.length-1){
if(stopped)break;
await apiCall(token,`/channels/${ch.id}/messages`,'POST',{content:batch.join('\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n')});
batch=[];
await sleep(800);
}}
log(`✓ Done: ${cat.n}`,'ok');
await sleep(500);
}
if(!stopped){
setProgress(100);
log('✅ DEPLOYMENT COMPLETE!','ok');
showStatus('success','✅','DEPLOYMENT COMPLETE',`All ${CATS.length} channels created with 240+ tools. Open Discord!`);
}
}catch(err){
log(`ERROR: ${err.message}`,'err');
showStatus('error','❌','FAILED',`${err.message} — Check token and that bot is in your server.`);
}
document.getElementById('deployBtn').disabled=false;
document.getElementById('stopBtn').style.display='none';
}
function stopDeploy(){stopped=true;document.getElementById('stopBtn').style.display='none';document.getElementById('deployBtn').disabled=false;}
function showStatus(type,icon,title,msg){const c=document.getElementById('statusCard');c.className=`status-card ${type}`;c.style.display='block';document.getElementById('statusIcon').textContent=icon;document.getElementById('statusTitle').textContent=title;document.getElementById('statusMsg').textContent=msg;}
</script>
