  --textlo: #3d5a6a;
  --texthi: #e0f0ff;
  --mono: 'Share Tech Mono', monospace;
  --orb: 'Orbitron', monospace;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:#b8ccd8;font-family:var(--mono);min-height:100vh;padding:20px 16px 40px;}
.wrap{max-width:600px;margin:0 auto;}
.logo{font-family:var(--orb);font-size:1.4rem;font-weight:900;color:var(--accent);letter-spacing:.1em;margin-bottom:4px;}
.logo span{color:var(--green);}
.sub{font-size:.65rem;color:var(--textlo);letter-spacing:.15em;text-transform:uppercase;margin-bottom:24px;}
.card{background:var(--panel);border:1px solid var(--border-hi);padding:20px;margin-bottom:16px;position:relative;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent);}
.label{font-size:.6rem;color:var(--accent);letter-spacing:.18em;text-transform:uppercase;margin-bottom:8px;display:block;}
.input{width:100%;background:#040a0f;border:1px solid var(--border-hi);color:var(--texthi);font-family:var(--mono);font-size:.8rem;padding:12px 14px;outline:none;}
.hint{font-size:.58rem;color:var(--textlo);margin-top:6px;line-height:1.5;}
.btn{width:100%;padding:16px;background:linear-gradient(135deg,#005a6e,#003d4a);border:1px solid var(--accent);color:var(--accent);font-family:var(--orb);font-size:.85rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;}
.btn:disabled{opacity:.4;}
.btn-stop{width:100%;padding:12px;background:linear-gradient(135deg,#6e0020,#4a0015);border:1px solid var(--red);color:var(--red);font-family:var(--orb);font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;margin-top:10px;display:none;}
.progress-wrap{margin-bottom:16px;display:none;}
.progress-label{font-size:.6rem;color:var(--textlo);letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;display:flex;justify-content:space-between;}
.progress-bar-bg{background:#040a0f;border:1px solid var(--border-hi);height:8px;}
.progress-bar-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--green));transition:width .3s;width:0%;}
.log-wrap{display:none;margin-bottom:16px;}
.log-label{font-size:.6rem;color:var(--textlo);letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;}
.log{background:#040a0f;border:1px solid var(--border-hi);height:200px;overflow-y:auto;padding:10px 12px;font-size:.65rem;line-height:1.8;}
.log-ok{color:var(--green);}
.log-err{color:var(--red);}
.log-info{color:var(--accent);}
.log-warn{color:var(--yellow);}
.status-card{display:none;background:var(--panel);border:1px solid;padding:20px;text-align:center;margin-bottom:16px;}
.status-card.success{border-color:var(--green);}
.status-card.error{border-color:var(--red);}
.status-icon{font-size:2.5rem;margin-bottom:10px;}
.status-title{font-family:var(--orb);font-size:.9rem;letter-spacing:.1em;margin-bottom:8px;}
.status-card.success .status-title{color:var(--green);}
.status-card.error .status-title{color:var(--red);}
.status-msg{font-size:.65rem;color:var(--textlo);line-height:1.7;}
.warning-box{background:#0a0005;border:1px solid #3d0010;padding:12px 14px;margin-bottom:16px;font-size:.62rem;color:#ff6688;line-height:1.7;}
</style>
