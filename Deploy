function log(msg,type='info'){const l=document.getElementById('log');const d=document.createElement('div');d.className=`log-${type}`;const t=new Date().toLocaleTimeString();d.textContent=`[${t}] ${msg}`;l.appendChild(d);l.scrollTop=l.scrollHeight;}
function setProgress(p){document.getElementById('progressBar').style.width=p+'%';document.getElementById('progressPct').textContent=Math.round(p)+'%';}
function sleep(ms){return new Promise(r=>setTimeout(r,ms));}
async function apiCall(token,endpoint,method='GET',body=null){const opts={method,headers:{'Authorization':`Bot ${token}`,'Content-Type':'application/json'}};if(body)opts.body=JSON.stringify(body);const res=await fetch(`https://discord.com/api/v10${endpoint}`,opts);if(res.status===429){const d=await res.json();const w=(d.retry_after||1)*1000+200;log(`Rate limited — waiting ${Math.round(w/1000)}s...`,'warn');await sleep(w);return apiCall(token,endpoint,method,body);}return res;}
